    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:mumbai": "hardhat run scripts/deploy.js --network polygonMumbai",
    "trader:help": "node scripts/trading_example.js",
    "trader:markets": "node scripts/trading_example.js markets",
    "trader:orderbook": "node scripts/trading_example.js orderbook",
    "trader:buy": "node scripts/trading_example.js buy",
    "trader:sell": "node scripts/trading_example.js sell",
    "trader:orders": "node scripts/trading_example.js orders",
    "trader:trades": "node scripts/trading_example.js trades",
    "trader:invest": "node scripts/trading_example.js invest",
    "filter:markets": "python high_price_market_filter.py"
  },
