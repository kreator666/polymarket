# ============================================
# Polymarket 交易环境配置
# ============================================

# --------------------------------------------
# 区块链 RPC 配置
# --------------------------------------------
# Polygon 主网 RPC (可从 https://chainlist.org/chain/137 获取)
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygon Mumbai 测试网 RPC (测试用)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygonscan API Key (用于验证合约)
POLYGONSCAN_API_KEY=your-polygonscan-api-key

# --------------------------------------------
# 钱包配置
# --------------------------------------------
# 私钥 (用于签名交易和派生 API 凭证)
# 警告: 不要在代码中硬编码私钥！使用环境变量
PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# --------------------------------------------
# 签名类型
# --------------------------------------------
# 0 = EOA (独立钱包，自己支付 gas)
# 1 = POLY_PROXY (Magic Link 登录的 Polymarket 账户)
# 2 = GNOSIS_SAFE (浏览器钱包登录的 Polymarket 账户，最常见)
SIGNATURE_TYPE=2

# 资金账户地址 (如果使用类型 1 或 2，需要填写代理钱包地址)
# 可在 polymarket.com/settings 查看
FUNDER_ADDRESS=0x...

# --------------------------------------------
# Polymarket API 配置
# --------------------------------------------
# CLOB API 地址 (Polygon 主网)
CLOB_API_URL=https://clob.polymarket.com

# Gamma API 地址 (用于获取市场数据)
GAMMA_API_URL=https://gamma-api.polymarket.com

# 链 ID (Polygon 主网 = 137, Mumbai = 80001)
CHAIN_ID=137

# --------------------------------------------
# 交易配置
# --------------------------------------------
# 默认下单金额 (USDC)
DEFAULT_TRADE_AMOUNT=100

# 默认滑点保护 (%)
DEFAULT_SLIPPAGE=0.05

# 订单类型: GTC, GTD, FOK, FAK
DEFAULT_ORDER_TYPE=GTC

# --------------------------------------------
# Gas 报告 (可选)
# --------------------------------------------
REPORT_GAS=false
